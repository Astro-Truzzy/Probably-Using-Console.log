# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://probably-using-console.log

# Admin dashboard password (required in production)
ADMIN_PASSWORD=change-me-in-production

# --- Supabase (required on Vercel for posts, comments, likes) ---
# Project URL: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Service role key: server-only, never expose as NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (required on Vercel for contact + newsletter) ---
# API key: https://resend.com/api-keys
RESEND_API_KEY=
# Verified sender in Resend (use onboarding@resend.dev for testing)
RESEND_FROM_EMAIL=onboarding@resend.dev
# Where contact form submissions are delivered
CONTACT_NOTIFY_EMAIL=you@example.com
# Optional public social profile URLs
# NEXT_PUBLIC_GITHUB_URL=https://github.com/Astro-Truzzy
# NEXT_PUBLIC_TWITTER_URL=
# NEXT_PUBLIC_LINKEDIN_URL=
