# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://probably-using-console.log

# Admin dashboard password (required in production)
ADMIN_PASSWORD=change-me-in-production
# HMAC secret for signed admin sessions (min 16 chars; required in production)
ADMIN_SESSION_SECRET=generate-a-long-random-string-here
# Secret terminal phrase to unlock /admin (case-insensitive, not shown in help)
ADMIN_TERMINAL_COMMAND=domain expansion

# --- Upstash Redis (required in production for comment/like rate limits) ---
# Vercel: Marketplace → Upstash → Upstash for Redis → Connect to this project.
# Vercel injects env vars automatically (names depend on the integration prefix):
# UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN
# or STORAGE_URL / STORAGE_TOKEN (default Vercel marketplace prefix)
# Legacy migrated KV: KV_REST_API_URL / KV_REST_API_TOKEN

# --- Supabase (required on Vercel for posts, comments, likes) ---
# Project URL: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Service role key: server-only, never expose as NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (required on Vercel for contact + newsletter) ---
# API key: https://resend.com/api-keys
RESEND_API_KEY=
# Verified sender in Resend (use onboarding@resend.dev for testing)
RESEND_FROM_EMAIL=onboarding@resend.dev
# Where contact form submissions are delivered
CONTACT_NOTIFY_EMAIL=you@example.com
# Optional public social profile URLs
# NEXT_PUBLIC_GITHUB_URL=https://github.com/Astro-Truzzy
# NEXT_PUBLIC_TWITTER_URL=
# NEXT_PUBLIC_LINKEDIN_URL=
